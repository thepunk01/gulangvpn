{
  "version": "1.0.0",
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "bundle": {
    "active": true,
    "longDescription": "孤狼加速 - 基于 Clash Verge Rev 的定制版本",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources"
    ],
    "publisher": "孤狼加速",
    "externalBin": [
      "sidecar/verge-mihomo",
      "sidecar/verge-mihomo-alpha"
    ],
    "copyright": "GNU General Public License v3.0",
    "category": "DeveloperTool",
    "shortDescription": "孤狼加速",
    "createUpdaterArtifacts": true
  },
  "build": {
    "beforeBuildCommand": "pnpm run web:build",
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run web:dev",
    "devUrl": "http://localhost:3000/",
    "removeUnusedCommands": true
  },
  "productName": "孤狼加速",
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQyOEMyRjBCQkVGOUJEREYKUldUZnZmbStDeStNMHU5Mmo1N24xQXZwSVRYbXA2NUpzZE5oVzlqeS9Bc0t6RVV4MmtwVjBZaHgK",
      "endpoints": [
        "https://download.clashverge.dev/https://github.com/thepunk01/gulangvpn/releases/download/updater/update-proxy.json",
        "https://gh-proxy.com/https://github.com/thepunk01/gulangvpn/releases/download/updater/update-proxy.json",
        "https://github.com/thepunk01/gulangvpn/releases/download/updater/update.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "clash",
          "clash-verge",
          "gulangvpn"
        ]
      }
    }
  },
  "app": {
    "security": {
      "capabilities": [
        "desktop-capability",
        "migrated"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "**"
          ],
          "requireLiteralLeadingDot": false
        }
      },
      "csp": null
    }
  },
  "identifier": "com.gulangvpn.app"
}